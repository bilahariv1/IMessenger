{
    "name": "imessenger",
    "version": "1.0.0",
    "description": "WhatsApp-like Messenger App",
    "main": "backend/app.js",
    "type": "module",
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    },
    "scripts": {
        "install:all": "npm install --prefix backend && npm install --prefix frontend",
        "build": "npm run build --prefix frontend",
        "start": "npm start --prefix backend",
        "dev": "npm run dev:all --prefix backend",
        "seed": "npm run seed --prefix backend",
        "heroku-postbuild": "npm install --prefix backend && npm install --prefix frontend && npm run build --prefix frontend"
    },
    "keywords": [
        "messenger",
        "whatsapp",
        "chat"
    ],
    "author": "",
    "license": "MIT"
}