# Production Environment Configuration
# For Heroku deployment with MongoDB Atlas

# MongoDB Atlas connection string
# Get this from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster0.mongodb.net/imessenger?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/imessenger?retryWrites=true&w=majority

# Heroku automatically assigns PORT
PORT=5000

# Production environment flag
NODE_ENV=production
