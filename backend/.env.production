# Production Environment Configuration
# Replace all values with your production credentials

# MongoDB - Use production MongoDB instance
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/imessenger?retryWrites=true&w=majority

# Server
PORT=5000
NODE_ENV=production

# Facebook WhatsApp API Configuration (Production)
WHATSAPP_ACCESS_TOKEN=your_production_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_production_phone_number_id_here
WHATSAPP_API_VERSION=v22.0
